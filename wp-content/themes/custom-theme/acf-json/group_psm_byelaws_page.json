        },
        {
            "key": "field_psm_byelaws_body",
            "label": "Body Text",
            "name": "byelaws_body",
            "type": "textarea",
            "instructions": "One paragraph per line.",
            "rows": 4,
            "default_value": "The Commissioners of Port St Mary have made a number of byelaws & orders relating to Port St Mary, based upon those issued by Government and used by other local authorities.\r\nThese regulations cover a range of topics relating to public behaviour, amenities, environmental responsibilities, and the use of community spaces.\r\nThe various documents can be downloaded below:",
            "conditional_logic": [
                [
                    {
                        "field": "field_psm_byelaws_title",
                        "operator": "!=empty"
                    }
                ]
            ]
        },
        {
            "key": "field_psm_byelaws_documents",
            "label": "Documents",
            "name": "byelaws_documents",
            "type": "repeater",
            "instructions": "PDF download links. A link is shown only when both label and PDF are provided.",
            "layout": "block",
            "min": 0,
            "max": 0,
            "collapsed": "field_psm_byelaws_document_label",
            "button_label": "Add Document",
            "conditional_logic": [
                [
                    {
                        "field": "field_psm_byelaws_title",
                        "operator": "!=empty"
                    }
                ]
            ],
            "sub_fields": [
                {
                    "key": "field_psm_byelaws_document_label",
                    "label": "Label",
                    "name": "byelaws_document_label",
                    "type": "text",
                    "wrapper": { "width": "50" },
                    "parent_repeater": "field_psm_byelaws_documents"
                },
                {
                    "key": "field_psm_byelaws_document_file",
                    "label": "PDF File",
                    "name": "byelaws_document_file",
                    "type": "file",
                    "return_format": "url",
                    "mime_types": "pdf",
                    "wrapper": { "width": "50" },
                    "conditional_logic": [
                        [
                            {
                                "field": "field_psm_byelaws_document_label",
                                "operator": "!=empty"
                            }
                        ]
                    ],
                    "parent_repeater": "field_psm_byelaws_documents"
                }
            ]
        }
