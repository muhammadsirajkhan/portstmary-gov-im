            "default_value": "Proudly Serving Our Community Since 1890"
        },
        {
            "key": "field_psm_inner_banner_intro_comm",
            "label": "Intro",
            "name": "inner_banner_intro",
            "type": "textarea",
            "instructions": "Description paragraph in the banner.",
            "default_value": "Meet the team behind Port St Mary Commissioners and discover how we serve residents through local services, facilities, and community support.",
            "rows": 3,
            "new_lines": ""
        },
        {
            "key": "field_psm_inner_banner_image_comm",
            "label": "Background Image",
            "name": "inner_banner_image",
            "type": "image",
            "instructions": "Banner background image.",
