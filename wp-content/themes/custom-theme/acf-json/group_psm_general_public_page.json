            "default_value": "Applying For Housing"
        },
        {
            "key": "field_psm_applying_intro",
            "label": "Intro",
            "name": "applying_intro",
            "type": "textarea",
            "instructions": "Intro below heading. Use a blank line between paragraphs.",
            "default_value": "Residents interested in applying for housing can complete an application form and submit the required information for review.\r\n\r\nApplications are assessed based on eligibility, housing availability, and community needs.",
