                    "label": "Description",
                    "name": "step_text",
                    "type": "textarea",
                    "instructions": "Card description.",
                    "rows": 2,
                    "conditional_logic": [
                        [
                            {
                                "field": "field_psm_step_title",
                                "operator": "!=empty"
                            }
                        ]
                    ],
                    "default_value": "Provide your personal and housing information.",
                    "parent_repeater": "field_psm_applying_steps"
                },
                {
                    "key": "field_psm_step_icon",
                    "label": "Icon (PNG)",
                    "name": "step_icon",
                    "type": "image",
                    "instructions": "Step icon image (PNG recommended).",
                    "return_format": "url",
                    "library": "all",
                    "mime_types": "png,jpg,jpeg,webp,svg",
                    "preview_size": "thumbnail",
                    "conditional_logic": [
                        [
                            {
                                "field": "field_psm_step_title",
                                "operator": "!=empty"
                            }
                        ]
                    ],
                    "parent_repeater": "field_psm_applying_steps"
                },
